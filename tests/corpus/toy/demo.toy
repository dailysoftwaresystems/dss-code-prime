var threshold : int = 10;

func add(a : int, b : int) -> int {
  return a + b;
}

func max(a : int, b : int) -> int {
  if (a < b) {
    return b;
  } else {
    return a;
  }
}

func countdown(n : int) -> void {
  while (0 < n) {
    var step : int = n - 1;
    return;
  }
}

func compute(n : int) -> int {
  var doubled : int = n * 2;
  var neg : int = -doubled;
  var shifted : int = doubled - threshold;
  return max(shifted, add(n, threshold));
}

func main() -> int {
  add(threshold, 1);
  return compute(threshold);
}

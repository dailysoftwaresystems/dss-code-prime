dsshir 1
symbols {
  %1 "threshold"
  %2 "add"
  %3 "a"
  %4 "b"
  %5 "compute"
  %6 "n"
  %7 "doubled"
}
module "Toy" {
  global %1 : i32 = lit int 10 : i32
  function %2 : fn(i32, i32) -> i32 {
    param %3 : i32
    param %4 : i32
    block {
      return binop Add : i32 (ref %3 : i32, ref %4 : i32)
    }
  }
  function %5 : fn(i32) -> i32 {
    param %6 : i32
    block {
      var %7 : i32 = binop Mul : i32 (ref %6 : i32, lit int 2 : i32)
      if (binop Lt : bool (ref %7 : i32, ref %1 : i32))
        block {
          return ref %7 : i32
        }
      else
        block {
          return call : i32 (ref %2 : fn(i32, i32) -> i32, ref %7 : i32, ref %1 : i32)
        }
    }
  }
}

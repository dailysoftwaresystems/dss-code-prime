{
  "dssSchemaVersion": 4,

  "language": {
    "name":           "CSubset",
    "version":        "0.1.0",
    "fileExtensions": [".c", ".h"]
  },

  "artifactProfiles": ["cli", "lib", "staticlib"],

  "imports": {
    "strategy":      "include-following",
    "directiveRule": "includeDirective",
    "pathToken":     "StringStart"
  },

  "lexerModes": {
    "main":          { "tokens": "default" },
    "string":        { "defaultToken": { "kind": "StringLiteral", "coalesce": true } },
    "charBody":      { "defaultToken": { "kind": "CharLiteral",   "coalesce": true } },
    "line-comment":  {
      "defaultToken":    { "kind": "CommentChar", "flags": ["EmptySpace"] },
      "unterminatedAs":  "comment"
    },
    "block-comment": {
      "defaultToken":    { "kind": "CommentChar", "flags": ["EmptySpace"] },
      "unterminatedAs":  "comment"
    }
  },

  "tokens": {
    " ":  [{ "kind": "Whitespace", "flags": ["EmptySpace"] }],
    "\t": [{ "kind": "Whitespace", "flags": ["EmptySpace"] }],
    "\n": [{ "kind": "Newline",    "flags": ["EmptySpace"] }],
    "\r": [{ "kind": "Whitespace", "flags": ["EmptySpace"] }],

    "//": [{
      "kind": "LineCommentStart", "flags": ["EmptySpace"],
      "modeOp": "pushMode", "modeArg": "line-comment",
      "stringStyle": { "escapeKind": "none", "endsAt": "\n" }
    }],
    "/*": [{
      "kind": "BlockCommentStart", "flags": ["EmptySpace"],
      "modeOp": "pushMode", "modeArg": "block-comment",
      "stringStyle": { "escapeKind": "none", "endsAt": "*/" }
    }],

    "(":  [{ "kind": "ParenOpen",     "opensScope": "Paren"   }],
    ")":  [{ "kind": "ParenClose",    "closesScope": true     }],
    "{":  [{ "kind": "BlockOpen",     "opensScope": "Block"   }],
    "}":  [{ "kind": "BlockClose",    "closesScope": true     }],
    "[":  [{ "kind": "BracketOpen",   "opensScope": "Bracket" }],
    "]":  [{ "kind": "BracketClose",  "closesScope": true     }],

    ";":  [{ "kind": "EndStatement" }],
    ",":  [{ "kind": "Comma" }],
    ":":  [{ "kind": "Colon" }],

    "#": [{ "kind": "HashOp" }],
    "\"": [{
      "kind": "StringStart",
      "modeOp": "pushMode", "modeArg": "string",
      "stringStyle": { "escapeKind": "char", "escapeChar": "\\", "endsAt": "\"" }
    }],
    "'": [{
      "kind": "CharStart",
      "modeOp": "pushMode", "modeArg": "charBody",
      "stringStyle": { "escapeKind": "char", "escapeChar": "\\", "endsAt": "'" }
    }],

    "=":  [{ "kind": "AssignOp" }],
    "+":  [{ "kind": "PlusOp"   }],
    "-":  [{ "kind": "MinusOp"  }],
    "*":  [{ "kind": "StarOp"   }],
    "/":  [{ "kind": "SlashOp"  }],
    "!":  [{ "kind": "BangOp"   }],
    "?":  [{ "kind": "QuestionOp" }],

    "==": [{ "kind": "EqEqOp" }],
    "!=": [{ "kind": "NotEqOp" }],
    "<":  [{ "kind": "LtOp" }],
    ">":  [{ "kind": "GtOp" }],
    "<=": [{ "kind": "LtEqOp" }],
    ">=": [{ "kind": "GtEqOp" }],
    "&&": [{ "kind": "AndAndOp" }],
    "||": [{ "kind": "OrOrOp"  }],

    "&":  [{ "kind": "BitAndOp" }],
    "|":  [{ "kind": "BitOrOp"  }],
    "^":  [{ "kind": "BitXorOp" }],
    "~":  [{ "kind": "TildeOp"  }],
    "<<": [{ "kind": "ShlOp"    }],
    ">>": [{ "kind": "ShrOp"    }],

    "++": [{ "kind": "PlusPlusOp" }],
    "--": [{ "kind": "MinusMinusOp" }],

    ".":  [{ "kind": "DotOp"   }],
    "->": [{ "kind": "ArrowOp" }],
    "...":[{ "kind": "EllipsisOp" }],

    "+=":  [{ "kind": "PlusAssignOp"   }],
    "-=":  [{ "kind": "MinusAssignOp"  }],
    "*=":  [{ "kind": "StarAssignOp"   }],
    "/=":  [{ "kind": "SlashAssignOp"  }],
    "%=":  [{ "kind": "ModAssignOp"    }],
    "&=":  [{ "kind": "BitAndAssignOp" }],
    "|=":  [{ "kind": "BitOrAssignOp"  }],
    "^=":  [{ "kind": "BitXorAssignOp" }],
    "<<=": [{ "kind": "ShlAssignOp"    }],
    ">>=": [{ "kind": "ShrAssignOp"    }]
  },

  "operators": {
    "groups": [
      { "precedence": 15, "associativity": "right",                      "operators": ["=", "+=", "-=", "*=", "/=", "%=", "&=", "|=", "^=", "<<=", ">>="] },
      { "precedence": 16, "associativity": "right", "arity": "ternary",   "operators": ["?"], "middle": ":"                       },
      { "precedence": 20, "associativity": "left",                       "operators": ["||"]                                   },
      { "precedence": 25, "associativity": "left",                       "operators": ["&&"]                                   },
      { "precedence": 30, "associativity": "left",                       "operators": ["|"]                                    },
      { "precedence": 35, "associativity": "left",                       "operators": ["^"]                                    },
      { "precedence": 40, "associativity": "left",                       "operators": ["&"]                                    },
      { "precedence": 50, "associativity": "left",                       "operators": ["==", "!="]                             },
      { "precedence": 55, "associativity": "left",                       "operators": ["<", ">", "<=", ">="]                   },
      { "precedence": 60, "associativity": "left",                       "operators": ["<<", ">>"]                             },
      { "precedence": 65, "associativity": "left",                       "operators": ["+", "-"]                               },
      { "precedence": 70, "associativity": "left",                       "operators": ["*", "/"]                               },
      { "precedence": 90, "associativity": "right", "arity": "prefix",   "operators": ["!", "~", "-", "*", "&"]                },
      { "precedence": 95,                            "arity": "postfix",  "operators": ["++", "--"]                            },
      { "precedence": 100,                           "arity": "postfix",  "operators": ["("], "endsAt": ")", "bodyRule": "argList" },
      { "precedence": 100,                           "arity": "postfix",  "operators": ["["], "endsAt": "]", "bodyRule": "expression" },
      { "precedence": 100,                           "arity": "postfix",  "operators": ["."],  "followerRule": "memberFollower" },
      { "precedence": 100,                           "arity": "postfix",  "operators": ["->"], "followerRule": "memberFollower" }
    ]
  },

  "numberStyle": {
    "decimal": true,
    "integerPrefixes": [
      { "prefix": "0x", "radix": 16, "digits": "0-9a-fA-F" },
      { "prefix": "0X", "radix": 16, "digits": "0-9a-fA-F" },
      { "prefix": "0b", "radix": 2,  "digits": "01"        },
      { "prefix": "0B", "radix": 2,  "digits": "01"        },
      { "prefix": "0o", "radix": 8,  "digits": "0-7"       },
      { "prefix": "0O", "radix": 8,  "digits": "0-7"       },
      { "prefix": "0",  "radix": 8,  "digits": "0-7"       }
    ],
    "exponent":         { "letters": ["e", "E"], "signOptional": true },
    "fractionPoint":    ".",
    "digitSeparator":   "_",
    "integerSuffixes":  ["u", "U", "l", "L", "ll", "LL", "ul", "UL", "lu", "LU",
                          "ull", "ULL", "llu", "LLU"],
    "floatSuffixes":    ["f", "F"],
    "emitKind":         { "integer": "IntLiteral", "float": "FloatLiteral" }
  },

  "syncTokens": ["EndStatement", "BlockClose"],

  "keywords": [
    { "word": "include", "kind": "IncludeKeyword" },

    { "word": "void",    "kind": "VoidKeyword"    },
    { "word": "int",     "kind": "IntKeyword"     },
    { "word": "char",    "kind": "CharKeyword"    },
    { "word": "const",   "kind": "ConstKeyword"   },
    { "word": "typedef", "kind": "TypedefKeyword" },
    { "word": "struct",  "kind": "StructKeyword"  },
    { "word": "union",   "kind": "UnionKeyword"   },
    { "word": "enum",    "kind": "EnumKeyword"    },

    { "word": "if",      "kind": "IfKeyword"      },
    { "word": "else",    "kind": "ElseKeyword"    },
    { "word": "while",   "kind": "WhileKeyword"   },
    { "word": "do",      "kind": "DoKeyword"      },
    { "word": "for",     "kind": "ForKeyword"     },
    { "word": "return",  "kind": "ReturnKeyword"  },
    { "word": "switch",  "kind": "SwitchKeyword"  },
    { "word": "case",    "kind": "CaseKeyword"    },
    { "word": "default", "kind": "DefaultKeyword" },
    { "word": "break",    "kind": "BreakKeyword"    },
    { "word": "continue", "kind": "ContinueKeyword" },

    { "word": "extern",  "kind": "ExternKeyword"  }
  ],

  "shapes": {
    "root": { "sequence": [ { "repeat": "topLevel" } ] },

    "topLevel": {
      "alt": [
        "includeDirective",
        "typedefDecl",
        "structDecl",
        "unionDecl",
        "enumDecl",
        "topLevelDecl",
        "externDecl"
      ]
    },

    "structDecl": {
      "sequence": [
        "StructKeyword", "Identifier",
        "BlockOpen",
        { "repeat": "structField" },
        "BlockClose",
        "EndStatement"
      ]
    },

    "structField": {
      "sequence": [ "typeRefAllowingStruct", "Identifier", "EndStatement" ]
    },

    "structTypeRef": {
      "sequence": [ "StructKeyword", "Identifier" ]
    },

    "unionDecl": {
      "sequence": [
        "UnionKeyword", "Identifier",
        "BlockOpen",
        { "repeat": "unionField" },
        "BlockClose",
        "EndStatement"
      ]
    },

    "unionField": {
      "sequence": [ "typeRefAllowingStruct", "Identifier", "EndStatement" ]
    },

    "unionTypeRef": {
      "sequence": [ "UnionKeyword", "Identifier" ]
    },

    "enumDecl": {
      "sequence": [
        "EnumKeyword", "Identifier",
        "BlockOpen",
        { "optional": {
            "sequence": [
              "enumerator",
              { "repeat": { "sequence": [ "Comma", { "optional": "enumerator" } ] } }
            ]
        }},
        "BlockClose",
        "EndStatement"
      ]
    },

    "enumerator": {
      "sequence": [
        "Identifier",
        { "optional": { "sequence": [ "AssignOp", "expression" ] } }
      ]
    },

    "enumTypeRef": {
      "sequence": [ "EnumKeyword", "Identifier" ]
    },

    "memberFollower": {
      "sequence": [ "Identifier" ]
    },

    "topLevelDecl": {
      "sequence": [ "typeRef", "Identifier", "topLevelDeclTail" ]
    },

    "topLevelDeclTail": {
      "alt": [ "funcDefTail", "varDeclTail" ]
    },

    "funcDefTail": {
      "sequence": [ "funcParams", "block" ]
    },

    "funcParams": {
      "sequence": [ "ParenOpen", { "optional": "paramList" }, "ParenClose" ]
    },

    "typedefDecl": {
      "sequence": [ "TypedefKeyword", "typeRefAllowingStruct", "Identifier", "EndStatement" ]
    },

    "includeDirective": {
      "sequence": [ "HashOp", "IncludeKeyword", "StringStart", "StringLiteral" ]
    },

    "externDecl": {
      "sequence": [
        "ExternKeyword",
        "typeRef",
        "Identifier",
        "externTail"
      ]
    },

    "externFuncTail": {
      "sequence": [
        "ParenOpen",
        { "optional": "paramList" },
        "ParenClose",
        { "optional": "stringLiteralExpr" },
        "EndStatement"
      ]
    },

    "externTail": {
      "alt": [
        "externFuncTail",
        "varDeclTail"
      ]
    },

    "varDeclTail": {
      "sequence": [
        { "optional": "arrayDeclSuffix" },
        { "optional": { "sequence": [ "AssignOp", "initValue" ] } },
        "EndStatement"
      ]
    },

    "initValue": { "alt": [ "braceInitList", "expression" ] },

    "arrayDeclSuffix": {
      "sequence": [
        "BracketOpen",
        { "optional": "expression" },
        "BracketClose"
      ]
    },

    "typeBase": { "alt": [ "VoidKeyword", "IntKeyword", "CharKeyword", "Identifier" ] },

    "typeRef": {
      "sequence": [
        { "optional": "ConstKeyword" },
        "typeBase",
        { "repeat": "StarOp" },
        { "optional": "ConstKeyword" }
      ]
    },

    "typeBaseAllowingStruct": {
      "alt": [ "VoidKeyword", "IntKeyword", "CharKeyword", "structTypeRef", "unionTypeRef", "enumTypeRef" ]
    },

    "typeRefAllowingStruct": {
      "sequence": [
        { "optional": "ConstKeyword" },
        "typeBaseAllowingStruct",
        { "repeat": "StarOp" },
        { "optional": "ConstKeyword" }
      ]
    },

    "varDeclHead": {
      "sequence": [
        "typeRefAllowingStruct",
        "Identifier",
        { "optional": "arrayDeclSuffix" },
        { "optional": { "sequence": [ "AssignOp", "initValue" ] } }
      ]
    },

    "varDecl": { "sequence": [ "varDeclHead", "EndStatement" ] },

    "paramList": {
      "sequence": [
        "param",
        { "repeat": { "sequence": [ "Comma", "paramOrEllipsis" ] } }
      ]
    },

    "param": { "sequence": [ "typeRefAllowingStruct", "Identifier" ] },

    "paramOrEllipsis": {
      "alt": [
        "param",
        "ellipsisParam"
      ]
    },
    "ellipsisParam": { "sequence": [ "EllipsisOp" ] },

    "block": {
      "sequence": [
        "BlockOpen",
        { "repeat": "statement" },
        "BlockClose"
      ]
    },

    "statement": {
      "alt": [
        "varDecl",
        "block",
        "ifStmt",
        "whileStmt",
        "doStmt",
        "forStmt",
        "switchStmt",
        "breakStmt",
        "continueStmt",
        "returnStmt",
        "exprStmt"
      ]
    },

    "ifStmt": {
      "sequence": [
        "IfKeyword",
        "ParenOpen", "expression", "ParenClose",
        "statement",
        { "optional": { "sequence": [ "ElseKeyword", "statement" ] } }
      ]
    },

    "whileStmt": {
      "sequence": [
        "WhileKeyword",
        "ParenOpen", "expression", "ParenClose",
        "statement"
      ]
    },

    "doStmt": {
      "sequence": [
        "DoKeyword",
        "statement",
        "WhileKeyword",
        "ParenOpen", "expression", "ParenClose",
        "EndStatement"
      ]
    },

    "forStmt": {
      "sequence": [
        "ForKeyword",
        "ParenOpen",
        { "optional": { "alt": [ "varDeclHead", "expression" ] } },
        "EndStatement",
        { "optional": "expression" },
        "EndStatement",
        { "optional": "expression" },
        "ParenClose",
        "statement"
      ]
    },

    "returnStmt": {
      "sequence": [
        "ReturnKeyword",
        { "optional": "expression" },
        "EndStatement"
      ]
    },

    "breakStmt":    { "sequence": [ "BreakKeyword",    "EndStatement" ] },
    "continueStmt": { "sequence": [ "ContinueKeyword", "EndStatement" ] },

    "switchStmt": {
      "sequence": [
        "SwitchKeyword",
        "ParenOpen", "expression", "ParenClose",
        "BlockOpen",
        { "repeat": "switchBodyItem" },
        "BlockClose"
      ]
    },

    "switchBodyItem": { "alt": [ "caseLabel", "statement" ] },

    "caseLabel": {
      "alt": [
        { "sequence": [ "CaseKeyword", "expression", "Colon" ] },
        { "sequence": [ "DefaultKeyword", "Colon" ] }
      ]
    },


    "exprStmt": { "sequence": [ "expression", "EndStatement" ] },

    "expression": {
      "expr": {
        "atom": "operand",
        "wrapperRules": {
          "binary":  "binaryExpr",
          "unary":   "unaryExpr",
          "postfix": "postfixExpr",
          "ternary": "ternaryExpr"
        }
      }
    },

    "operand": {
      "alt": [
        "Identifier",
        "IntLiteral",
        "FloatLiteral",
        "stringLiteralExpr",
        "charLiteralExpr",
        "compoundLiteralExpr",
        "parenExpr"
      ],
      "speculative": true,
      "lookahead": 8
    },

    "parenExpr": { "sequence": [ "ParenOpen", "expression", "ParenClose" ] },

    "compoundLiteralExpr": {
      "sequence": [ "ParenOpen", "typeRefAllowingStruct", "ParenClose", "braceInitList" ]
    },

    "braceInitList": {
      "sequence": [
        "BlockOpen",
        { "optional": {
            "sequence": [
              "initElement",
              { "repeat": { "sequence": [ "Comma", { "optional": "initElement" } ] } }
            ]
        }},
        "BlockClose"
      ]
    },

    "initElement": {
      "alt": [
        { "sequence": [
            "designator",
            { "repeat": "designator" },
            "AssignOp",
            "initValue"
        ]},
        "initValue"
      ]
    },

    "designator": { "alt": [ "designatedField", "designatedIndex" ] },
    "designatedField": { "sequence": [ "DotOp", "Identifier" ] },
    "designatedIndex": { "sequence": [ "BracketOpen", "expression", "BracketClose" ] },

    "charLiteralExpr":   { "sequence": [ "CharStart",   "CharLiteral"   ] },
    "stringLiteralExpr": { "sequence": [ "StringStart", "StringLiteral" ] },

    "argList": {
      "optional": {
        "sequence": [
          "expression",
          { "repeat": { "sequence": [ "Comma", "expression" ] } }
        ]
      }
    }
  },

  "semantics": {
    "identifierToken": "Identifier",
    "pointerToken":    "StarOp",
    "$externLibraryByFormatComment": "FF6 Slice 2 + audit fold (2026-06-02): per-format runtime library identity for source-declared externs. compileSingleUnit step 2.5 populates HirAttribute<FfiMetadata> per ExternFunction/ExternGlobal by calling synthesizeFfiFromSourceDecls() with the entry whose key matches objectFormatKindName(format.kind()). Per-LANGUAGE field (not per-declaration-rule) — the post-fold #1 placement on DeclarationRule was fragile; the pipeline first-match-loop would silently pick the wrong rule on grammars with multiple extern-shaped decl rules. Library identities: PE → msvcrt.dll (Win32 C runtime for x86_64 hello-world); ELF → libc.so.6 (glibc on Linux); Mach-O → /usr/lib/libSystem.B.dylib (libSystem dispatcher publishes the libc surface). Per-symbol overrides (`extern \"otherlib.dll\" int foo();`) anchored D-CSUBSET-EXTERN-LIBRARY-SYNTAX.",
    "externLibraryByFormat": {
      "pe":    "msvcrt.dll",
      "elf":   "libc.so.6",
      "macho": "/usr/lib/libSystem.B.dylib"
    },
    "$pointerConversionsComment": "D-LANG-POINTER-VOID-CONVERT (step 13.2, 2026-06-02): C-standard §6.3.2.3 — `void*` converts implicitly to/from any object-pointer type without a cast. The two directions are configured INDEPENDENTLY (matching C++'s split, where only the safe direction is implicit). c-subset declares BOTH true (C-family semantics). A future C++ frontend would declare {implicitToVoidPtr: true, implicitFromVoidPtr: false} matching ISO C++ §7.11. Rust/Swift would declare both false. DEFAULT is false (struct-init); strict typing is the safety-respecting default, opposite of the Array→Ptr decay opt-out direction (which is pervasive C-family idiom; void-ptr conversion is a safety relaxation). Pointer arithmetic on void* and void*↔fn-pointer conversions are separate concerns anchored at D-LANG-VOIDPTR-ARITH-REJECT and D-LANG-VOIDPTR-FN-CONVERT respectively.",
    "pointerConversions": {
      "implicitToVoidPtr":                  true,
      "implicitFromVoidPtr":                true,
      "nullPointerConstantFromIntegerZero": true
    },
    "$pointerAliasingComment": "Two orthogonal C99-derived alias-analysis opt-ins. `strictAliasingOnDistinctTypes` (C99 §6.5): accessing an object through a pointer of an incompatible type is undefined behavior — lets the MIR optimizer's CSE/LICM Load admission prove Ptr<I32> and Ptr<I64> don't alias (Rule 6 in mirMayAlias). `charTypesAliasAll` (C99 §6.5 ¶7): character-type pointers may alias an object of any type — the canonical strict-aliasing carve-out for serializers/hash-visitors/memcpy. C-family languages declare both true. A Rust frontend or strict-typed DSL would declare `charTypesAliasAll: false` (the type-checker enforces aliasing at a higher tier). See D-OPT-LOAD-ALIAS-ANALYSIS for the substrate's design.",
    "pointerAliasing": {
      "strictAliasingOnDistinctTypes":      true,
      "charTypesAliasAll":                  true
    },
    "declarations": [
      { "rule": "varDeclHead", "name": 1, "type": 0, "kind": "variable",
        "constMarker": "ConstKeyword", "warnIfUnused": true,
        "arraySuffix": { "rule": "arrayDeclSuffix", "lengthChild": 1 } },
      { "rule": "param",       "name": 1, "type": 0, "kind": "variable",
        "constMarker": "ConstKeyword" },
      { "rule": "topLevelDecl", "name": 1, "type": 0, "kind": "variable",
        "constMarker": "ConstKeyword",
        "arraySuffix": { "rule": "arrayDeclSuffix", "lengthChild": 1 },
        "kindByChild": {
          "childPath": [2, 0],
          "whenRule": "funcDefTail",
          "whenKind": "function",
          "paramsPath": [0],
          "bodyPath":   [1]
        },
        "$implicitReturnZeroForFunctionNamesComment": "C99 §5.1.2.2.3: when control reaches the closing '}' of main without an explicit return, the semantics are equivalent to 'return 0;'. The HIR lowering appends a synthetic ReturnStmt(IntLiteral(0)) to main's body if it doesn't structurally terminate. SOURCE-AGNOSTIC: this list lives on the per-language semantic config so each language declares its own entry-fn convention (Pascal's 'program', Rust's 'fn main', etc.) without touching shared HIR substrate. Closes D-LK10-ENTRY-MAIN-IMPLICIT-RETURN.",
        "implicitReturnZeroForFunctionNames": ["main"] },
      { "rule": "typedefDecl", "name": 2, "type": 1, "kind": "type" },
      { "rule": "structDecl",  "name": 1, "kind": "type",
        "fieldChildren": { "rule": "structField", "compositeKind": "struct" } },
      { "rule": "structField", "name": 1, "type": 0, "kind": "variable" },
      { "rule": "unionDecl",   "name": 1, "kind": "type",
        "fieldChildren": { "rule": "unionField", "compositeKind": "union" } },
      { "rule": "unionField",  "name": 1, "type": 0, "kind": "variable" },
      { "rule": "enumDecl",    "name": 1, "kind": "type",
        "fieldChildren": { "rule": "enumerator", "compositeKind": "enum",
                           "liftToEnclosingScope": true } },
      { "rule": "enumerator",  "name": 0, "kind": "variable" },
      { "rule": "externDecl", "name": 2, "type": 1, "kind": "variable",
        "kindByChild": {
          "childPath": [3, 0],
          "whenRule": "externFuncTail",
          "whenKind": "function",
          "paramsPath": [1]
        },
        "variadicMarker": "EllipsisOp",
        "arraySuffix": { "rule": "arrayDeclSuffix", "lengthChild": 1 } }
    ],
    "references": [
      { "rule": "operand" },
      { "rule": "structTypeRef", "nameMatch": "lastIdentifier" },
      { "rule": "unionTypeRef",  "nameMatch": "lastIdentifier" },
      { "rule": "enumTypeRef",   "nameMatch": "lastIdentifier" }
    ],
    "memberAccesses": [
      { "rule": "postfixExpr", "lhsChild": 0, "nameChild": 2,
        "dereferences": false, "operatorToken": "DotOp"   },
      { "rule": "postfixExpr", "lhsChild": 0, "nameChild": 2,
        "dereferences": true,  "operatorToken": "ArrowOp" }
    ],
    "scopes": [ "block", "funcDefTail", "structDecl", "unionDecl", "enumDecl" ],
    "assignments": [
      { "rule": "binaryExpr", "operatorToken": "AssignOp",       "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "PlusAssignOp",   "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "MinusAssignOp",  "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "StarAssignOp",   "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "SlashAssignOp",  "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "ModAssignOp",    "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "BitAndAssignOp", "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "BitOrAssignOp",  "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "BitXorAssignOp", "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "ShlAssignOp",    "lhs": 0, "rhs": 2 },
      { "rule": "binaryExpr", "operatorToken": "ShrAssignOp",    "lhs": 0, "rhs": 2 }
    ],
    "callRules": [
      { "rule": "postfixExpr", "callee": 0, "args": 2,
        "operatorToken": "ParenOpen" }
    ],
    "returnRules": [
      { "rule": "returnStmt", "value": 1 }
    ],
    "loopRules": [ "whileStmt", "forStmt", "doStmt", "switchStmt" ],
    "loopControls": [ { "rule": "breakStmt" }, { "rule": "continueStmt" } ],
    "builtinTypes": [
      { "name": "int",  "core": "I32"  },
      { "name": "char", "core": "Char" },
      { "name": "void", "core": "Void" }
    ],
    "literalTypes": [
      { "literal": "IntLiteral",   "core": "I32" },
      { "literal": "FloatLiteral", "core": "F64" }
    ]
  },

  "hirLowering": {
    "ruleMappings": [
      { "rule": "includeDirective", "hirKind": "Skip"    },
      { "rule": "topLevelDecl", "hirKind": "Decl"        },
      { "rule": "varDeclHead",  "hirKind": "VarDecl"     },
      { "rule": "param",        "hirKind": "VarDecl"     },
      { "rule": "typedefDecl",  "hirKind": "TypeDecl"    },
      { "rule": "structDecl",   "hirKind": "TypeDecl"    },
      { "rule": "unionDecl",    "hirKind": "TypeDecl"    },
      { "rule": "enumDecl",     "hirKind": "TypeDecl"    },
      { "rule": "externDecl",   "hirKind": "ExternDecl"  },
      { "rule": "block",        "hirKind": "Block"       },
      { "rule": "ifStmt",       "hirKind": "IfStmt"      },
      { "rule": "whileStmt",    "hirKind": "WhileStmt"   },
      { "rule": "doStmt",       "hirKind": "DoWhileStmt" },
      { "rule": "forStmt",      "hirKind": "ForStmt"     },
      { "rule": "switchStmt",   "hirKind": "SwitchStmt"  },
      { "rule": "breakStmt",    "hirKind": "BreakStmt"    },
      { "rule": "continueStmt", "hirKind": "ContinueStmt" },
      { "rule": "returnStmt",   "hirKind": "ReturnStmt"  },
      { "rule": "exprStmt",     "hirKind": "ExprStmt"    }
    ],

    "binaryExprRule":  "binaryExpr",
    "unaryExprRule":   "unaryExpr",
    "postfixExprRule": "postfixExpr",
    "ternaryExprRule": "ternaryExpr",
    "operandRule":     "operand",

    "braceInitListRule":   "braceInitList",
    "initElementRule":     "initElement",
    "designatedFieldRule": "designatedField",
    "designatedIndexRule": "designatedIndex",
    "compoundLiteralRule": "compoundLiteralExpr",

    "globalsConstEval": { "allowFloat": true },


    "binaryOps": [
      { "token": "PlusOp",   "target": "Add"    },
      { "token": "MinusOp",  "target": "Sub"    },
      { "token": "StarOp",   "target": "Mul"    },
      { "token": "SlashOp",  "target": "Div"    },
      { "token": "EqEqOp",   "target": "Eq"     },
      { "token": "NotEqOp",  "target": "Ne"     },
      { "token": "LtOp",     "target": "Lt"     },
      { "token": "LtEqOp",   "target": "Le"     },
      { "token": "GtOp",     "target": "Gt"     },
      { "token": "GtEqOp",   "target": "Ge"     },
      { "token": "AndAndOp", "target": "LogicalAnd" },
      { "token": "OrOrOp",   "target": "LogicalOr"  },
      { "token": "BitAndOp", "target": "BitAnd" },
      { "token": "BitOrOp",  "target": "BitOr"  },
      { "token": "BitXorOp", "target": "BitXor" },
      { "token": "ShlOp",    "target": "Shl"    },
      { "token": "ShrOp",    "target": "Shr"    },
      { "token": "AssignOp", "target": "Assign" },

      { "token": "PlusAssignOp",   "target": "Assign", "compoundBase": "Add"    },
      { "token": "MinusAssignOp",  "target": "Assign", "compoundBase": "Sub"    },
      { "token": "StarAssignOp",   "target": "Assign", "compoundBase": "Mul"    },
      { "token": "SlashAssignOp",  "target": "Assign", "compoundBase": "Div"    },
      { "token": "ModAssignOp",    "target": "Assign", "compoundBase": "Rem"    },
      { "token": "BitAndAssignOp", "target": "Assign", "compoundBase": "BitAnd" },
      { "token": "BitOrAssignOp",  "target": "Assign", "compoundBase": "BitOr"  },
      { "token": "BitXorAssignOp", "target": "Assign", "compoundBase": "BitXor" },
      { "token": "ShlAssignOp",    "target": "Assign", "compoundBase": "Shl"    },
      { "token": "ShrAssignOp",    "target": "Assign", "compoundBase": "Shr"    }
    ],

    "unaryOps": [
      { "token": "BangOp",   "target": "Not"       },
      { "token": "TildeOp",  "target": "BitNot"    },
      { "token": "MinusOp",  "target": "Neg"       },
      { "token": "BitAndOp", "target": "AddressOf" },
      { "token": "StarOp",   "target": "Deref"     }
    ],

    "postfixOps": [
      { "token": "ParenOpen",    "target": "Call"    },
      { "token": "BracketOpen",  "target": "Index"   },
      { "token": "PlusPlusOp",   "target": "PostInc" },
      { "token": "MinusMinusOp", "target": "PostDec" },
      { "token": "DotOp",        "target": "MemberAccess"       },
      { "token": "ArrowOp",      "target": "MemberAccessThruPtr"}
    ],

    "forClauseSeparator": "EndStatement",
    "caseLabelRule":      "caseLabel",
    "caseDefaultToken":   "DefaultKeyword",

    "charLiteral":   { "startToken": "CharStart",   "bodyToken": "CharLiteral"   },
    "stringLiteral": { "startToken": "StringStart", "bodyToken": "StringLiteral" }
  }
}

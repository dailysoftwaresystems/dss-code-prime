{
  "dssSchemaVersion": 4,

  "language": {
    "name":           "TsqlSubset",
    "version":        "0.1.0",
    "fileExtensions": [".sql", ".tsql"]
  },

  "artifactProfiles": ["script", "sproc"],

  "imports": {
    "strategy":         "name-matching",
    "nameRule":         "qualifiedName",
    "definitionRule":   "createTableStmt",
    "referenceParents": ["tableRef", "insertStmt", "updateStmt", "deleteStmt"],
    "nameToken":        "Identifier",
    "caseSensitive":    false
  },

  "reservedWordPolicy": "contextual",

  "numberStyle": {
    "decimal":          true,
    "exponent":         { "letters": ["e", "E"], "signOptional": true },
    "fractionPoint":    ".",
    "emitKind":         { "integer": "IntLiteral", "float": "FloatLiteral" }
  },

  "typeExtensions": [
    { "name": "TSQL::Varchar", "parameters": [ { "name": "N", "kind": "Integer" } ] }
  ],

  "syncTokens": ["EndStatement"],

  "lexerModes": {
    "main":            { "tokens": "default" },
    "bracket-id":      { "defaultToken": { "kind": "BracketIdChar" } },
    "single-string":   { "defaultToken": { "kind": "StringLiteral", "coalesce": true } },
    "unicode-string":  { "defaultToken": { "kind": "StringLiteral", "coalesce": true } },
    "line-comment":    {
      "defaultToken":    { "kind": "CommentChar", "flags": ["EmptySpace"] },
      "unterminatedAs":  "comment"
    },
    "block-comment":   {
      "defaultToken":    { "kind": "CommentChar", "flags": ["EmptySpace"] },
      "unterminatedAs":  "comment"
    }
  },

  "tokens": {
    " ":  [{ "kind": "Whitespace", "flags": ["EmptySpace"] }],
    "\t": [{ "kind": "Whitespace", "flags": ["EmptySpace"] }],
    "\n": [{ "kind": "Newline",    "flags": ["EmptySpace"] }],
    "\r": [{ "kind": "Whitespace", "flags": ["EmptySpace"] }],

    "--": [{
      "kind": "LineCommentStart", "flags": ["EmptySpace"],
      "modeOp": "pushMode", "modeArg": "line-comment",
      "stringStyle": { "escapeKind": "none", "endsAt": "\n" }
    }],
    "/*": [{
      "kind": "BlockCommentStart", "flags": ["EmptySpace"],
      "modeOp": "pushMode", "modeArg": "block-comment",
      "stringStyle": { "escapeKind": "none", "endsAt": "*/" }
    }],

    "(":  [{ "kind": "ParenOpen",  "opensScope": "Paren" }],
    ")":  [{ "kind": "ParenClose", "closesScope": true }],
    ";":  [{ "kind": "EndStatement" }],
    ",":  [{ "kind": "Comma" }],
    ".":  [{ "kind": "Dot" }],

    "*":  [{ "kind": "StarOp"   }],
    "+":  [{ "kind": "PlusOp"   }],
    "-":  [{ "kind": "MinusOp"  }],
    "/":  [{ "kind": "SlashOp"  }],
    "%":  [{ "kind": "ModOp"    }],

    "=":  [{ "kind": "EqOp"     }],
    "<":  [{ "kind": "LtOp"     }],
    ">":  [{ "kind": "GtOp"     }],
    "<=": [{ "kind": "LtEqOp"   }],
    ">=": [{ "kind": "GtEqOp"   }],
    "<>": [{ "kind": "NotEqOp"  }],
    "!=": [{ "kind": "NotEqOp2" }],

    "'":  [{
      "kind": "StringStart",
      "modeOp": "pushMode", "modeArg": "single-string",
      "stringStyle": { "escapeKind": "doubled-delimiter", "endsAt": "'" }
    }],
    "N'": [{
      "kind": "UnicodeStringStart",
      "modeOp": "pushMode", "modeArg": "unicode-string",
      "stringStyle": { "escapeKind": "doubled-delimiter", "endsAt": "'" }
    }],
    "[":  [{
      "kind": "BracketIdStart",
      "modeOp": "pushMode", "modeArg": "bracket-id",
      "stringStyle": { "escapeKind": "doubled-delimiter", "endsAt": "]" }
    }]
  },

  "operators": {
    "groups": [
      { "precedence": 10, "associativity": "left",                       "operators": ["="]                                  },
      { "precedence": 20, "associativity": "left",                       "operators": ["<>", "!=", "<", ">", "<=", ">="]    },
      { "precedence": 30, "associativity": "left",                       "operators": ["+", "-"]                            },
      { "precedence": 40, "associativity": "left",                       "operators": ["*", "/", "%"]                       },
      { "precedence": 90, "associativity": "right", "arity": "prefix",   "operators": ["-"]                                 }
    ]
  },

  "keywords": [
    { "word": "SELECT", "kind": "SelectKw" },
    { "word": "FROM",   "kind": "FromKw"   },
    { "word": "WHERE",  "kind": "WhereKw"  },
    { "word": "AS",     "kind": "AsKw"     },
    { "word": "AND",    "kind": "AndKw"    },
    { "word": "OR",     "kind": "OrKw"     },
    { "word": "NOT",    "kind": "NotKw"    },
    { "word": "NULL",   "kind": "NullKw"   },
    { "word": "IS",     "kind": "IsKw"     },
    { "word": "IN",     "kind": "InKw"     },
    { "word": "INSERT", "kind": "InsertKw" },
    { "word": "INTO",   "kind": "IntoKw"   },
    { "word": "VALUES", "kind": "ValuesKw" },
    { "word": "UPDATE", "kind": "UpdateKw" },
    { "word": "SET",    "kind": "SetKw"    },
    { "word": "DELETE", "kind": "DeleteKw" },
    { "word": "CREATE", "kind": "CreateKw" },
    { "word": "TABLE",  "kind": "TableKw"  },
    { "word": "INT",    "kind": "IntKw"    },
    { "word": "VARCHAR","kind": "VarcharKw" },
    { "word": "BIT",    "kind": "BitKw"    }
  ],

  "shapes": {
    "root": { "sequence": [ { "repeat": "statement" } ] },

    "statement": {
      "alt": [
        "selectStmt",
        "insertStmt",
        "updateStmt",
        "deleteStmt",
        "createTableStmt"
      ]
    },

    "selectStmt": {
      "sequence": [
        "SelectKw",
        "selectList",
        "FromKw",
        "tableRef",
        { "optional": "whereClause" },
        "EndStatement"
      ]
    },

    "tableRef": {
      "sequence": [
        "qualifiedName",
        { "optional": { "sequence": [
            { "optional": "AsKw" },
            "nameAtom"
          ] } }
      ]
    },

    "selectList": { "alt": [ "selectStar", "selectItemList" ] },
    "selectStar": { "sequence": [ "StarOp" ] },
    "selectItemList": {
      "sequence": [
        "selectItem",
        { "repeat": { "sequence": [ "Comma", "selectItem" ] } }
      ]
    },
    "selectItem": {
      "sequence": [
        "expression",
        { "optional": { "sequence": [ "AsKw", "nameAtom" ] } }
      ]
    },

    "whereClause": { "sequence": [ "WhereKw", "expression" ] },

    "qualifiedName": {
      "sequence": [
        "nameAtom",
        { "repeat": { "sequence": [ "Dot", "nameAtom" ] } }
      ]
    },
    "nameAtom": { "alt": [ "Identifier", "BracketIdStart" ] },

    "insertStmt": {
      "sequence": [
        "InsertKw", "IntoKw", "qualifiedName",
        { "optional": { "sequence": [ "ParenOpen", "columnList", "ParenClose" ] } },
        "ValuesKw",
        "ParenOpen", "valueList", "ParenClose",
        "EndStatement"
      ]
    },
    "columnList": {
      "sequence": [ "nameAtom", { "repeat": { "sequence": [ "Comma", "nameAtom" ] } } ]
    },
    "valueList": {
      "sequence": [ "expression", { "repeat": { "sequence": [ "Comma", "expression" ] } } ]
    },

    "updateStmt": {
      "sequence": [
        "UpdateKw", "qualifiedName", "SetKw", "assignList",
        { "optional": "whereClause" },
        "EndStatement"
      ]
    },
    "assignList": {
      "sequence": [ "assignment", { "repeat": { "sequence": [ "Comma", "assignment" ] } } ]
    },
    "assignment": { "sequence": [ "nameAtom", "EqOp", "expression" ] },

    "deleteStmt": {
      "sequence": [
        "DeleteKw", "FromKw", "qualifiedName",
        { "optional": "whereClause" },
        "EndStatement"
      ]
    },

    "createTableStmt": {
      "sequence": [
        "CreateKw", "TableKw", "qualifiedName",
        "ParenOpen", "columnDeclList", "ParenClose",
        "EndStatement"
      ]
    },
    "columnDeclList": {
      "sequence": [
        "columnDecl",
        { "repeat": { "sequence": [ "Comma", "columnDecl" ] } }
      ]
    },
    "columnDecl": {
      "sequence": [
        "nameAtom",
        "typeRef",
        { "optional": "notNullClause" }
      ]
    },
    "typeRef": { "alt": [ "IntKw", "VarcharKw", "BitKw" ] },
    "notNullClause": { "sequence": [ "NotKw", "NullKw" ] },

    "expression": {
      "sequence": [
        "operand",
        { "repeat": { "sequence": [ "binaryOp", "operand" ] } }
      ]
    },

    "binaryOp": {
      "alt": [
        "EqOp", "NotEqOp", "NotEqOp2", "LtOp", "GtOp", "LtEqOp", "GtEqOp",
        "PlusOp", "MinusOp", "StarOp", "SlashOp", "ModOp"
      ]
    },

    "operand": {
      "alt": [
        "nameOrCall",
        "IntLiteral",
        "stringLitExpr",
        "uniStringLitExpr",
        "NullKw",
        { "sequence": [ "MinusOp", "operand" ] },
        { "sequence": [ "ParenOpen", "expression", "ParenClose" ] }
      ]
    },

    "stringLitExpr":    { "sequence": [ "StringStart",        "StringLiteral" ] },
    "uniStringLitExpr": { "sequence": [ "UnicodeStringStart", "StringLiteral" ] },

    "nameOrCall": {
      "alt": [ "callExpr", "qualifiedName" ],
      "speculative": true
    },

    "callExpr": {
      "sequence": [
        "Identifier",
        "ParenOpen",
        { "optional": "callArgList" },
        "ParenClose"
      ]
    },

    "callArgList": {
      "sequence": [
        "expression",
        { "repeat": { "sequence": [ "Comma", "expression" ] } }
      ]
    }
  },

  "semantics": {
    "identifierToken": "Identifier",
    "bracketIdentifierToken": "BracketIdStart",
    "declarations": [
      { "rule": "createTableStmt", "name": 2, "kind": "table",
        "nameMatch": "lastIdentifier" },
      { "rule": "columnDecl", "name": 0, "type": 1, "kind": "variable" }
    ],
    "references": [
      { "rule": "qualifiedName", "nameMatch": "lastIdentifier",
        "hardParents": ["tableRef", "insertStmt", "updateStmt", "deleteStmt"] }
    ],
    "scopes": [ "createTableStmt" ],
    "callRules": [
      { "rule": "callExpr", "callee": 0, "args": 2 }
    ],
    "builtinFunctions": [
      { "name": "COALESCE", "result": "I32", "variadic": true }
    ],
    "builtinTypes": [
      { "name": "INT", "core": "I32" },
      { "name": "BIT", "core": "Bool" },
      { "name": "VARCHAR", "extension": "TSQL::Varchar" }
    ],
    "literalTypes": [
      { "literal": "IntLiteral", "core": "I32" }
    ]
  },

  "hirLowering": {
    "extensionKinds": [
      { "name": "TSQL::Select",      "lang": "TsqlSubset" },
      { "name": "TSQL::Insert",      "lang": "TsqlSubset" },
      { "name": "TSQL::Update",      "lang": "TsqlSubset" },
      { "name": "TSQL::Delete",      "lang": "TsqlSubset" },
      { "name": "TSQL::CreateTable", "lang": "TsqlSubset" },
      { "name": "TSQL::Projection",  "lang": "TsqlSubset" },
      { "name": "TSQL::Star",        "lang": "TsqlSubset" },
      { "name": "TSQL::ValueList",   "lang": "TsqlSubset" },
      { "name": "TSQL::ColumnList",  "lang": "TsqlSubset" },
      { "name": "TSQL::AssignList",  "lang": "TsqlSubset" },
      { "name": "TSQL::Assignment",  "lang": "TsqlSubset" },
      { "name": "TSQL::Columns",     "lang": "TsqlSubset" },
      { "name": "TSQL::Null",        "lang": "TsqlSubset" },
      { "name": "TSQL::Name",        "lang": "TsqlSubset" }
    ],

    "refExtensionKind": "TSQL::Name",

    "flatExprRule":     "expression",
    "flatBinaryOpRule": "binaryOp",
    "operandRule":      "operand",

    "stringLiteral":          { "startToken": "StringStart", "bodyToken": "StringLiteral" },
    "unicodeStringStartToken": "UnicodeStringStart",
    "stringDoubledDelimiter":  true,

    "nullLiteral": { "token": "NullKw", "hirKind": "TSQL::Null" },

    "binaryOps": [
      { "token": "PlusOp",   "target": "Add" },
      { "token": "MinusOp",  "target": "Sub" },
      { "token": "StarOp",   "target": "Mul" },
      { "token": "SlashOp",  "target": "Div" },
      { "token": "ModOp",    "target": "Rem" },
      { "token": "EqOp",     "target": "Eq"  },
      { "token": "NotEqOp",  "target": "Ne"  },
      { "token": "NotEqOp2", "target": "Ne"  },
      { "token": "LtOp",     "target": "Lt"  },
      { "token": "GtOp",     "target": "Gt"  },
      { "token": "LtEqOp",   "target": "Le"  },
      { "token": "GtEqOp",   "target": "Ge"  }
    ],
    "unaryOps": [
      { "token": "MinusOp", "target": "Neg" }
    ],

    "ruleMappings": [
      { "rule": "selectStmt", "hirKind": "TSQL::Select", "childGathering": [
        { "match": { "rule": "selectList" },                    "lower": "ext",      "role": "projection" },
        { "match": { "rule": "tableRef" },                      "lower": "ref",      "role": "from" },
        { "match": { "rule": "whereClause" }, "optional": true, "lower": "flatExpr", "role": "where" }
      ] },
      { "rule": "selectStar",     "hirKind": "TSQL::Star",      "childGathering": [] },
      { "rule": "selectItemList", "hirKind": "TSQL::Projection", "childGathering": [
        { "match": { "rule": "selectItem" }, "list": true, "lower": "flatExpr", "role": "items" }
      ] },

      { "rule": "insertStmt", "hirKind": "TSQL::Insert", "childGathering": [
        { "match": { "rule": "qualifiedName" },               "lower": "ref", "role": "target" },
        { "match": { "rule": "columnList" }, "optional": true, "lower": "ext", "role": "columns" },
        { "match": { "rule": "valueList" },                   "lower": "ext", "role": "values" }
      ] },
      { "rule": "columnList", "hirKind": "TSQL::ColumnList", "childGathering": [
        { "match": { "rule": "nameAtom" }, "list": true, "lower": "ref", "role": "columns" }
      ] },
      { "rule": "valueList", "hirKind": "TSQL::ValueList", "childGathering": [
        { "match": { "rule": "expression" }, "list": true, "lower": "flatExpr", "role": "values" }
      ] },

      { "rule": "updateStmt", "hirKind": "TSQL::Update", "childGathering": [
        { "match": { "rule": "qualifiedName" },                 "lower": "ref",      "role": "target" },
        { "match": { "rule": "assignList" },                    "lower": "ext",      "role": "assignments" },
        { "match": { "rule": "whereClause" }, "optional": true, "lower": "flatExpr", "role": "where" }
      ] },
      { "rule": "assignList", "hirKind": "TSQL::AssignList", "childGathering": [
        { "match": { "rule": "assignment" }, "list": true, "lower": "ext", "role": "assignments" }
      ] },
      { "rule": "assignment", "hirKind": "TSQL::Assignment", "childGathering": [
        { "match": { "rule": "nameAtom" },    "lower": "ref",      "role": "target" },
        { "match": { "rule": "expression" },  "lower": "flatExpr", "role": "value" }
      ] },

      { "rule": "deleteStmt", "hirKind": "TSQL::Delete", "childGathering": [
        { "match": { "rule": "qualifiedName" },                 "lower": "ref",      "role": "target" },
        { "match": { "rule": "whereClause" }, "optional": true, "lower": "flatExpr", "role": "where" }
      ] },

      { "rule": "createTableStmt", "hirKind": "TSQL::CreateTable", "childGathering": [
        { "match": { "rule": "qualifiedName" },  "lower": "ref", "role": "name" },
        { "match": { "rule": "columnDeclList" }, "lower": "ext", "role": "columns" }
      ] },
      { "rule": "columnDeclList", "hirKind": "TSQL::Columns", "childGathering": [
        { "match": { "rule": "columnDecl" }, "list": true, "lower": "varDecl", "role": "columns" }
      ] }
    ]
  }
}

# Golden-file tree pretty-prints — written and compared byte-exact by
# `tests/analysis/syntactic/test_corpus.cpp::checkGoldenTree`. Force LF
# regardless of `core.autocrlf` so a Windows checkout doesn't introduce
# CRLF and break the byte-equality compare on first run.
*.tree text eol=lf

# Test-corpus source inputs parsed end-to-end by `test_corpus.cpp`. Forcing
# LF prevents `core.autocrlf` from injecting CR bytes the shipped schemas
# need to declare explicitly as `Whitespace` lexemes (see e.g. c-subset.lang.json).
tests/corpus/** text eol=lf

# Shipped language + target config JSONs. Pinned to LF for the same reason
# as `tests/corpus/**`: the lexer treats `\r` as an explicit Whitespace lexeme,
# and the `D5_5_LiftOptOutRespected` test (and similar) substring-match against
# the file with bare `\n` separators. Without this pin, a Windows `core.autocrlf`
# checkout rewrites configs to CRLF and the test fails on CI even though local
# tests pass.
src/dss-config/** text eol=lf

# Curated runnable-corpus sources (examples/<lang>/<name>/). The V2-4 Part C
# expect-error harness asserts diagnostic POSITIONS (line:col) resolved from
# these source bytes, so pin LF: a Windows `core.autocrlf` checkout that
# injected CR would shift byte offsets between the compiler's read and the
# runner's source read, mis-resolving the asserted line:col.
examples/** text eol=lf

# FC17.9(h) C23 `#embed` resource files. A committed binary resource (e.g. the
# c23_embed example's answer.bin, whose bytes include 0x0D CR / 0x0A LF / 0x1A
# SUB) MUST NOT be CRLF-normalized by the `examples/** text eol=lf` rule above —
# that would corrupt the bytes `#embed` reads, failing ONLY on fresh clones / CI.
# This later line WINS by last-match precedence, marking every examples `.bin`
# strictly binary (byte-identical on every checkout). The self-witnessing example
# (blob[1] == 13) is the red canary if this is ever lost.
examples/**/*.bin binary

# `.dsshir` HIR text-format goldens — emitted with LF by `emitHir` and compared
# byte-exact by the HIR text + lowering golden tests (test_hir_text.cpp,
# test_hir_lowering_*.cpp). Without this a Windows `core.autocrlf` checkout
# rewrites them to CRLF and the byte-compare diverges on `\r` (CI: windows-msvc).
*.dsshir text eol=lf

# LSP replay session goldens — line-compared by test_lsp_replay.cpp. The reader
# already strips trailing CR, but pin LF so the goldens are platform-stable.
tests/lsp/sessions/** text eol=lf

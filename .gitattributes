# Golden-file tree pretty-prints — written and compared byte-exact by
# `tests/analysis/syntactic/test_corpus.cpp::checkGoldenTree`. Force LF
# regardless of `core.autocrlf` so a Windows checkout doesn't introduce
# CRLF and break the byte-equality compare on first run.
*.tree text eol=lf

# Test-corpus source inputs parsed end-to-end by `test_corpus.cpp`. Forcing
# LF prevents `core.autocrlf` from injecting CR bytes the shipped schemas
# need to declare explicitly as `Whitespace` lexemes (see e.g. c-subset.lang.json).
tests/corpus/** text eol=lf

# `.dsshir` HIR text-format goldens — emitted with LF by `emitHir` and compared
# byte-exact by the HIR text + lowering golden tests (test_hir_text.cpp,
# test_hir_lowering_*.cpp). Without this a Windows `core.autocrlf` checkout
# rewrites them to CRLF and the byte-compare diverges on `\r` (CI: windows-msvc).
*.dsshir text eol=lf

# LSP replay session goldens — line-compared by test_lsp_replay.cpp. The reader
# already strips trailing CR, but pin LF so the goldens are platform-stable.
tests/lsp/sessions/** text eol=lf
